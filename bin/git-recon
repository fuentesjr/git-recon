#!/usr/bin/env bash
# git-recon — history-first codebase investigation.
# Style: Google Shell Style Guide, with two deliberate deviations: env shebang
# (macOS /bin/bash is 3.2) and `set -eu` without pipefail (sections pipe
# through `head`, which SIGPIPEs upstream sort under pipefail).
#
# Self-contained port of the review aliases in dotfiles/git/.gitconfig, for
# use on machines/containers that don't have those aliases. Output is plain
# text and capped for consumption by AI agents as well as humans.
#
# Run `git-recon explain` for how to interpret each section.
set -eu

# Analysis windows and output caps. Tune here; raw git is the escape hatch
# when an investigation needs a different window.
readonly RECENT_DAYS=90
readonly RECENT_MAX=50
readonly CHURN_WINDOW='1 year ago'
readonly CHURN_MAX=30
readonly CHURN_DIRS_MAX=20
readonly AUTHORS_WINDOW='6 months ago'
readonly AUTHORS_MAX=25
readonly BUG_FILES_MAX=20
readonly HOTSPOT_COMMITS=25
readonly COUPLING_MAX=20
readonly COUPLING_MAX_COMMIT_FILES=30
readonly RISK_MAX=20
readonly SILOS_MAX=20
readonly FIX_RATE_MAX=20
readonly FIX_RATE_MIN_COMMITS=5
readonly TEST_GAP_MAX=20

die() { printf 'git-recon: %s\n' "$*" >&2; exit 1; }

usage() {
  cat <<'EOF'
git-recon — investigate a codebase through its git history

Usage: git-recon <command> [args]

First pass:
  overview             recent activity, churn, ownership, repairs in one shot

Drill-down (after overview points somewhere):
  hotspot <path>       commit history with per-commit stats for one path
  owners <path>        top contributors for a file/dir
  blame [-L a,b] <file>  whitespace-insensitive blame with short dates

Deeper analysis:
  deep                 coupling, risk, silos, fix-rate, test-gap in one shot
  coupling [<path>]    files that change together, last year
  risk                 churn weighted by current indentation complexity
  silos                majority ownership and inactive-owner risk
  fix-rate             repair-shaped commits as a share of file changes
  test-gap             logic changes accompanied by test changes

Individual sections (subsets of overview):
  vitals               repo scale: commit/file/author counts and concentration
  recent               commit stream, last 90 days
  churn                most-changed files, last year
  churn-dirs           most-changed directories, last year
  authors              active contributors, last 6 months
  repairs              bug-fix-shaped files + incident/rollback commits
  monthly              commit volume by month (full history)

Guidance:
  explain              how to interpret each section (read once first)
EOF
}

explain() {
  cat <<'EOF'
git-recon: interpreting the output
===================================

Purpose: before reading code in an unfamiliar repo, use history to decide
what to read first. Churn and repair patterns expose recurring behavior over
time, not just the current snapshot.

Recommended sequence:
  1. git-recon overview
  2. For risk or instability work, run git-recon deep.
  3. Pick a suspicious file or directory from the resulting signals.
  4. git-recon hotspot <path>   — what does its history look like?
  5. git-recon owners <path>    — who is likely to have context?
  6. git-recon blame -L a,b <file> — who last touched those lines?
  7. Read the code with that context.

Section notes and caveats:

vitals      Scale calibration for every other section: 42 commits on a file
            means something different in a 300-commit repo than a 90k-commit
            monorepo. The author line is a rough bus-factor hint; "recent
            commits" counts across all refs, no merges.

recent      Cadence, naming style, revert frequency; whether bots or release
            commits dominate. Fastest feel for the repo's current workflow.

churn       High churn suggests complexity, instability, or active product
churn-dirs  work. First check whether top entries are real logic or expected
            glue (routes, lockfiles, generated code). churn-dirs is more
            useful than churn in large repos. The share footer says how much
            of total change activity the capped list covers: a high share
            means hotspot-driven, a low share means change is spread out and
            the ranking matters less.

authors     Current-activity hint, not bus factor. Who has recent context.

repairs     == bug-files ==   files recurring in commits whose message matches
            fix|bug|broken. Commit-message heuristic — quality of the signal
            depends on commit-message discipline in the repo.
            == firefights ==  commits matching revert|hotfix|emergency|rollback.
            Narrower and more operational; good for spotting instability or
            rollback-heavy periods.

coupling    Files that often change in the same commit. High counts suggest
            coordination or a hidden dependency; pass a path to focus on its
            partners. Commits over 30 files are skipped as likely sweeps, and
            the one-year window can miss older or slower-moving relationships.

risk        One-year churn weighted by current lines times maximum indentation
            depth. High scores prioritize hot, structurally dense files over
            routine glue. Indentation is only a complexity proxy; current-tree
            complexity is combined with historical churn, so renames and large
            rewrites can make the two sides of the score disagree.

silos       For hot files, the majority author, their commit share, and whether
            they are active in the last six months. High-share INACTIVE entries
            flag orphaned-knowledge risk. Commit counts are not line ownership
            and do not capture reviews, pairing, or uncommitted expertise.

fix-rate    Repair-shaped commits divided by all commits for frequently changed
            files. High rates suggest repeated repair relative to activity;
            files need at least five commits. Like repairs, this depends on
            commit-message discipline and is not a defect-rate measurement.

test-gap    For hot non-test files, the share of commits that also changed a
            test file; low values are the gap signal. This is the flakiest
            heuristic here: path naming drives classification, so monorepos and
            unconventional test layouts can break it.

monthly     Rough activity trend. Not a team-health metric; volume is heavily
            shaped by workflow (squash vs merge, bots, release automation).

hotspot     Per-commit stats for one path. Look for repeated repair work,
            large edits, or a long tail of small patches. Capped at 25
            commits; use `git log --stat --follow -- <path>` for everything.

owners      Commit counts for one path. More useful than repo-wide counts
            when you are already focused on an area.

blame       Whitespace-insensitive, so formatting-only changes don't
            distract. Add `-L start,end` before the file to focus on a range.

General caveats:
- All of this is signal, not proof. Corroborate before concluding.
- Shallow clones and squash-merge workflows weaken every section.
- jj-native repos (no .git directory) are not supported; use `jj` directly.
EOF
}

# Caps ranked "count name" lines from stdin at $1 rows and appends a share
# footer, so a truncated list still says how much of the total it covers
# (whether the repo is hotspot-driven or the distribution is flat).
share_cap() {
  awk -v max="$1" -v noun="$2" '
    {
      total_changes += $1
      total_names++
      if (NR <= max) {
        shown += $1
        print
      }
    }
    END {
      if (total_changes > 0) {
        printf "(top %d of %d %s = %d%% of %d changes in last year)\n",
          (total_names < max ? total_names : max), total_names, noun,
          int(100 * shown / total_changes), total_changes
      }
    }'
}

vitals() {
  [[ $# -eq 0 ]] || die 'usage: git-recon vitals'
  local first_date total_commits window_commits touched tracked all_authors

  first_date="$(git log --reverse --date=short --format=%ad | head -1)"
  total_commits="$(git rev-list --count HEAD)"
  window_commits="$(git rev-list --count --since="$CHURN_WINDOW" HEAD)"
  touched="$(git log --format=format: --name-only --since="$CHURN_WINDOW" \
    | sed '/^$/d' | sort -u | wc -l | tr -d ' ')"
  tracked="$(git ls-files | wc -l | tr -d ' ')"
  all_authors="$(git shortlog -sn --all --no-merges | wc -l | tr -d ' ')"

  printf 'commits: %s all-time (first %s), %s in last year\n' \
    "$total_commits" "$first_date" "$window_commits"
  printf 'files: %s touched in last year, %s tracked\n' "$touched" "$tracked"
  git shortlog -sn --since="$AUTHORS_WINDOW" --all --no-merges \
    | awk -v all="$all_authors" '
        NR == 1 {
          top_count = $1
          top = $0
          sub(/^[[:space:]]*[0-9]+[[:space:]]+/, "", top)
        }
        { active++; recent += $1 }
        END {
          if (recent > 0) {
            printf "authors: %d active in last 6 months of %d all-time; ",
              active, all
            printf "top: %s (%d%% of recent commits)\n",
              top, int(100 * top_count / recent)
          } else {
            printf "authors: 0 active in last 6 months of %d all-time\n", all
          }
        }'
}

recent() {
  git log --date=short --pretty=format:'%ad %h %an %s' \
    --since="${RECENT_DAYS}.days.ago" | head -"$RECENT_MAX"
}

churn() {
  git log --format=format: --name-only --since="$CHURN_WINDOW" \
    | sed '/^$/d' | sort | uniq -c | sort -rn \
    | share_cap "$CHURN_MAX" files
}

churn_dirs() {
  git log --format=format: --name-only --since="$CHURN_WINDOW" \
    | sed '/^$/d' | sed 's,/[^/]*$,,' | sort | uniq -c | sort -rn \
    | share_cap "$CHURN_DIRS_MAX" dirs
}

authors() {
  git shortlog -sn --since="$AUTHORS_WINDOW" --all --no-merges \
    | head -"$AUTHORS_MAX"
}

bug_files() {
  git log -i -E --grep='fix|bug|broken' --name-only --format= \
    --since="$CHURN_WINDOW" \
    | sed '/^$/d' | sort | uniq -c | sort -rn | head -"$BUG_FILES_MAX"
}

firefights() {
  git log --oneline -i --extended-regexp --since="$CHURN_WINDOW" \
    --grep=revert --grep=hotfix --grep=emergency --grep=rollback
}

repairs() {
  echo '== bug-files =='
  bug_files
  printf '\n== firefights ==\n'
  firefights
}

monthly() {
  git log --format=%ad --date=format:%Y-%m | sort | uniq -c
}

owners() {
  [[ $# -gt 0 ]] || die 'usage: git-recon owners <path>'
  git shortlog -sn --all --no-merges -- "$@"
}

hotspot() {
  [[ $# -gt 0 ]] || die 'usage: git-recon hotspot <path>'
  git log -n "$HOTSPOT_COMMITS" --stat --follow -- "$1"
  printf '\n(last %s commits; git log --stat --follow -- %s shows all)\n' \
    "$HOTSPOT_COMMITS" "$1"
}

blame() {
  [[ $# -gt 0 ]] || die 'usage: git-recon blame [-L start,end] <file>'
  git blame -w --date=short "$@"
}

coupling() {
  [[ $# -le 1 ]] || die 'usage: git-recon coupling [<path>]'
  local target="${1:-}"

  target="${target#./}"
  target="${target%/}"
  git log --format=format:--COMMIT-- --name-only --since="$CHURN_WINDOW" \
    | awk -v max_files="$COUPLING_MAX_COMMIT_FILES" -v target="$target" '
      function matches_target(file) {
        return target != "" && (file == target || index(file, target "/") == 1)
      }
      function count_commit(    files, file_count, file, i, j, left, right, key,
                                has_target) {
        file_count = 0
        has_target = 0
        for (file in commit_files) {
          files[++file_count] = file
          if (matches_target(file)) {
            has_target = 1
          }
        }
        # Skip large commits: mass reformats/sweeps would otherwise pollute
        # every file coupling count with one unrelated one-off event.
        if (file_count > max_files) {
          return
        }
        if (target != "") {
          if (!has_target) {
            return
          }
          # Exclude files belonging to the target from its own partner
          # counts: a multi-file target (a directory) should not count
          # itself as a partner.
          for (i = 1; i <= file_count; i++) {
            if (!matches_target(files[i])) {
              counts[files[i]]++
            }
          }
          return
        }
        for (i = 1; i <= file_count; i++) {
          for (j = i + 1; j <= file_count; j++) {
            left = files[i]
            right = files[j]
            # Canonicalize left<right so pair (a,b) and (b,a) share one
            # counted key instead of splitting across two SUBSEP entries.
            if (right < left) {
              file = left
              left = right
              right = file
            }
            key = left SUBSEP right
            counts[key]++
          }
        }
      }
      /^--COMMIT--$/ {
        count_commit()
        delete commit_files
        next
      }
      NF { commit_files[$0] = 1 }
      END {
        # The final commit has no trailing --COMMIT-- sentinel to trigger
        # count_commit(), so it must be counted explicitly here.
        count_commit()
        if (target != "") {
          for (file in counts) {
            printf "%d %s\n", counts[file], file
          }
        } else {
          for (key in counts) {
            split(key, pair, SUBSEP)
            printf "%d %s -- %s\n", counts[key], pair[1], pair[2]
          }
        }
      }
    ' | sort -k1,1nr -k2,2 | head -"$COUPLING_MAX"
  printf '(top %s; commits over %s files skipped)\n' \
    "$COUPLING_MAX" "$COUPLING_MAX_COMMIT_FILES"
}

risk() {
  [[ $# -eq 0 ]] || die 'usage: git-recon risk'
  local temp_dir
  local churn_file
  local complexity_file

  temp_dir="$(mktemp -d "${TMPDIR:-/tmp}/git-recon-risk.XXXXXX")"
  churn_file="${temp_dir}/churn"
  complexity_file="${temp_dir}/complexity"

  git log --format=format: --name-only --since="$CHURN_WINDOW" \
    | awk 'NF { counts[$0]++ } END {
        for (file in counts) {
          printf "%d\t%s\n", counts[file], file
        }
      }' > "$churn_file"

  # -I -l -z selects tracked, non-binary, non-empty files (via -e ''); this
  # is the only filter that excludes binaries from the complexity score.
  # LC_ALL=C keeps xargs/awk byte-based, avoiding locale-dependent handling
  # of non-UTF8 filenames.
  # shellcheck disable=SC2016  # single-quoted awk program, not shell expansion
  git grep -Il -z -e '' \
    | LC_ALL=C xargs -0 -n 200 awk '
        function emit_file() {
          if (current_file != "") {
            printf "%d\t%s\n", lines * max_depth, current_file
          }
        }
        # xargs -0 -n 200 splits files across separate awk invocations;
        # FNR (not NR) resets per file, so FNR==1 marks a new-file boundary.
        # emit_file() flushes the previous file there, and again in END for
        # the last file of each batch (no next file left to trigger it).
        FNR == 1 {
          emit_file()
          current_file = FILENAME
          lines = 0
          max_depth = 0
        }
        {
          lines++
          match($0, /^[ \t]*/)
          indent = substr($0, 1, RLENGTH)
          spaces = 0
          tabs = 0
          for (i = 1; i <= length(indent); i++) {
            if (substr(indent, i, 1) == "\t") {
              tabs++
            } else {
              spaces++
            }
          }
          depth = tabs + int(spaces / 2)
          if (depth > max_depth) {
            max_depth = depth
          }
        }
        END { emit_file() }
      ' > "$complexity_file"

  echo 'score churn complexity file'
  # Tab-delimited (not space) since filenames may themselves contain spaces.
  # Ties break on churn, skipping complexity; filename is the final key so
  # output order is always deterministic.
  awk -F '\t' '
      FILENAME == ARGV[1] {
        separator = index($0, "\t")
        complexity[substr($0, separator + 1)] = substr($0, 1, separator - 1)
        next
      }
      {
        churn = $1
        file = substr($0, index($0, "\t") + 1)
        # Files churned but since deleted/renamed have no complexity entry
        # (built from the current tree above) and drop out here.
        if (file in complexity) {
          printf "%.0f %d %d %s\n", churn * complexity[file], churn,
            complexity[file], file
        }
      }
    ' "$complexity_file" "$churn_file" \
    | sort -k1,1nr -k2,2nr -k4,4 | head -"$RISK_MAX"
  printf '(top %s files)\n' "$RISK_MAX"
  rm -rf "$temp_dir"
}

silos() {
  [[ $# -eq 0 ]] || die 'usage: git-recon silos'
  local temp_dir
  local top_files
  local active_authors

  temp_dir="$(mktemp -d "${TMPDIR:-/tmp}/git-recon-silos.XXXXXX")"
  top_files="${temp_dir}/top-files"
  active_authors="${temp_dir}/active-authors"

  git log --format=format: --name-only --since="$CHURN_WINDOW" \
    | sed '/^$/d' | sort | uniq -c | sort -rn | head -"$SILOS_MAX" \
    | sed 's/^[[:space:]]*[0-9][0-9]*[[:space:]]//' > "$top_files"
  # Uncapped (no head): this only tests set membership, unlike the
  # head-capped display sections, so every active author must be present.
  git shortlog -sn --since="$AUTHORS_WINDOW" --all --no-merges \
    | sed 's/^[[:space:]]*[0-9][0-9]*[[:space:]]*//' > "$active_authors"

  git log --format=format:--AUTHOR--%an --name-only --since="$CHURN_WINDOW" \
    | awk '
        FILENAME == ARGV[1] { top[$0] = 1; next }
        FILENAME == ARGV[2] { active[$0] = 1; next }
        /^--AUTHOR--/ {
          # --AUTHOR-- sentinel is 10 chars; substr from 11 strips it,
          # leaving the %an name that follows on the same line.
          author = substr($0, 11)
          next
        }
        NF && ($0 in top) {
          total[$0]++
          author_count[$0 SUBSEP author]++
        }
        END {
          for (file in top) {
            majority = ""
            majority_count = 0
            # for-in order is unspecified; break ties by author name so
            # the majority pick does not vary run-to-run on equal counts.
            for (key in author_count) {
              split(key, parts, SUBSEP)
              if (parts[1] == file &&
                  (author_count[key] > majority_count ||
                   (author_count[key] == majority_count &&
                    (majority == "" || parts[2] < majority)))) {
                majority = parts[2]
                majority_count = author_count[key]
              }
            }
            if (total[file] > 0) {
              share = int(100 * majority_count / total[file])
              state = (majority in active) ? "active" : "INACTIVE"
              printf "%d%% %s %s %s\n", share, state, majority, file
            }
          }
        }
      ' "$top_files" "$active_authors" - \
    | sort -k1,1nr -k2,2 -k4,4 | head -"$SILOS_MAX"
  printf '(top %s churn files)\n' "$SILOS_MAX"
  rm -rf "$temp_dir"
}

fix_rate() {
  [[ $# -eq 0 ]] || die 'usage: git-recon fix-rate'
  local temp_dir
  local total_file
  local fixes_file

  temp_dir="$(mktemp -d "${TMPDIR:-/tmp}/git-recon-fix-rate.XXXXXX")"
  total_file="${temp_dir}/total"
  fixes_file="${temp_dir}/fixes"

  git log --format=format: --name-only --since="$CHURN_WINDOW" \
    | awk 'NF { counts[$0]++ } END {
        for (file in counts) {
          printf "%d\t%s\n", counts[file], file
        }
      }' > "$total_file"
  git log -i -E --grep='fix|bug|broken' --name-only --format= \
    --since="$CHURN_WINDOW" \
    | awk 'NF { counts[$0]++ } END {
        for (file in counts) {
          printf "%d\t%s\n", counts[file], file
        }
      }' > "$fixes_file"

  awk -F '\t' -v minimum="$FIX_RATE_MIN_COMMITS" '
      FILENAME == ARGV[1] {
        separator = index($0, "\t")
        total[substr($0, separator + 1)] = substr($0, 1, separator - 1)
        next
      }
      FILENAME == ARGV[2] {
        separator = index($0, "\t")
        fixes[substr($0, separator + 1)] = substr($0, 1, separator - 1)
        next
      }
      END {
        for (file in total) {
          # Floor avoids noisy rates from tiny samples (e.g. 1/1 = 100%).
          if (total[file] >= minimum) {
            fix_count = (file in fixes) ? fixes[file] : 0
            rate = int(100 * fix_count / total[file])
            printf "%d%% %d/%d %s\n", rate, fix_count, total[file], file
          }
        }
      }
    ' "$total_file" "$fixes_file" \
    | sort -k1,1nr -k2,2r -k3,3 | head -"$FIX_RATE_MAX"
  printf '(top %s; files need at least %s commits)\n' \
    "$FIX_RATE_MAX" "$FIX_RATE_MIN_COMMITS"
  rm -rf "$temp_dir"
}

test_gap() {
  [[ $# -eq 0 ]] || die 'usage: git-recon test-gap'
  local temp_dir
  local top_files

  temp_dir="$(mktemp -d "${TMPDIR:-/tmp}/git-recon-test-gap.XXXXXX")"
  top_files="${temp_dir}/top-files"

  git log --format=format: --name-only --since="$CHURN_WINDOW" \
    | sed '/^$/d' | sort | uniq -c | sort -rn \
    | awk '
        function is_test(file) {
          return file ~ /(^|\/)(test|tests|spec|__tests__)\// ||
            file ~ /(^|\/)[^\/]+_(test|spec)\.[^\/]+$/ ||
            file ~ /(^|\/)[^\/]+\.(test|spec)\.[^\/]+$/
        }
        {
          sub(/^[[:space:]]*[0-9][0-9]*[[:space:]]/, "")
          if (!is_test($0)) {
            printf "%s\n", $0
            found++
            # Exiting early (not breaking) stops reading the piped input;
            # like piping into head, this can SIGPIPE the upstream sort,
            # which is exactly why this script does not set pipefail.
            if (found == max_files) {
              exit
            }
          }
        }
      ' max_files="$TEST_GAP_MAX" > "$top_files"

  git log --format=format:--COMMIT-- --name-only --since="$CHURN_WINDOW" \
    | awk '
        function is_test(file) {
          return file ~ /(^|\/)(test|tests|spec|__tests__)\// ||
            file ~ /(^|\/)[^\/]+_(test|spec)\.[^\/]+$/ ||
            file ~ /(^|\/)[^\/]+\.(test|spec)\.[^\/]+$/
        }
        function count_commit(    file, has_test) {
          has_test = 0
          for (file in commit_files) {
            if (is_test(file)) {
              has_test = 1
            }
          }
          # has_test is commit-wide: any test file in the commit marks
          # every one of its top files covered, not just files whose own
          # tests changed in that commit.
          for (file in commit_files) {
            if (file in top) {
              total[file]++
              if (has_test) {
                covered[file]++
              }
            }
          }
        }
        FILENAME == ARGV[1] { top[$0] = 1; next }
        /^--COMMIT--$/ {
          count_commit()
          delete commit_files
          next
        }
        NF { commit_files[$0] = 1 }
        END {
          count_commit()
          for (file in top) {
            if (total[file] > 0) {
              rate = int(100 * covered[file] / total[file])
              printf "%d%% %d %s\n", rate, total[file], file
            }
          }
        }
      ' "$top_files" - \
    | sort -k1,1n -k2,2nr -k3,3 | head -"$TEST_GAP_MAX"
  printf '(top %s non-test churn files)\n' "$TEST_GAP_MAX"
  rm -rf "$temp_dir"
}

deep() {
  [[ $# -eq 0 ]] || die 'usage: git-recon deep'
  printf '== coupling (last year, top %s pairs) ==\n' "$COUPLING_MAX"
  coupling
  printf '\n== risk (last year, top %s files) ==\n' "$RISK_MAX"
  risk
  printf '\n== silos (last year, top %s churn files) ==\n' "$SILOS_MAX"
  silos
  printf '\n== fix-rate (last year, top %s files) ==\n' "$FIX_RATE_MAX"
  fix_rate
  printf '\n== test-gap (last year, top %s churn files) ==\n' "$TEST_GAP_MAX"
  test_gap
}

overview() {
  printf '== vitals ==\n'
  vitals
  printf '\n== recent (last %s days, first %s) ==\n' "$RECENT_DAYS" "$RECENT_MAX"
  recent
  printf '\n\n== churn (last year, top %s files) ==\n' "$CHURN_MAX"
  churn
  printf '\n== churn-dirs (last year, top %s dirs) ==\n' "$CHURN_DIRS_MAX"
  churn_dirs
  printf '\n== authors (last 6 months, top %s) ==\n' "$AUTHORS_MAX"
  authors
  printf '\n== repairs (last year) ==\n\n'
  repairs
}

main() {
  local cmd="${1:-help}"
  shift || true

  case "$cmd" in
    help|-h|--help) usage; exit 0 ;;
    explain) explain; exit 0 ;;
  esac

  git rev-parse --git-dir >/dev/null 2>&1 \
    || die 'not a git repository (jj-native repos unsupported; use jj directly)'

  case "$cmd" in
    overview)   overview ;;
    vitals)     vitals "$@" ;;
    recent)     recent; echo ;;
    churn)      churn ;;
    churn-dirs) churn_dirs ;;
    authors)    authors ;;
    repairs)    repairs ;;
    monthly)    monthly ;;
    owners)     owners "$@" ;;
    hotspot)    hotspot "$@" ;;
    blame)      blame "$@" ;;
    deep)       deep "$@" ;;
    coupling)   coupling "$@" ;;
    risk)       risk "$@" ;;
    silos)      silos "$@" ;;
    fix-rate)   fix_rate "$@" ;;
    test-gap)   test_gap "$@" ;;
    *)          usage >&2; die "unknown command: $cmd" ;;
  esac
}

main "$@"
