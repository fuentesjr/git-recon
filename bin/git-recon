#!/usr/bin/env bash
# git-recon — history-first codebase investigation.
# Style: Google Shell Style Guide, with two deliberate deviations: env shebang
# (macOS /bin/bash is 3.2) and `set -eu` without pipefail (sections pipe
# through `head`, which SIGPIPEs upstream sort under pipefail).
#
# Self-contained port of the review aliases in dotfiles/git/.gitconfig, for
# use on machines/containers that don't have those aliases. Human-oriented
# report output is plain text and capped for AI agents as well as humans.
#
# Run `git-recon explain` for how to interpret each section.
set -eu

# Analysis windows and output caps. Tune here; raw git is the escape hatch
# when an investigation needs a different window.
readonly RECENT_DAYS=90
readonly RECENT_MAX=50
readonly CHURN_WINDOW='1 year ago'
readonly CHURN_MAX=30
readonly CHURN_DIRS_MAX=20
readonly AUTHORS_WINDOW='6 months ago'
readonly AUTHORS_MAX=25
readonly BUG_FILES_MAX=20
readonly HOTSPOT_COMMITS=25
readonly COUPLING_MAX=20
readonly COUPLING_MAX_COMMIT_FILES=30
readonly RISK_MAX=20
readonly SILOS_MAX=20
readonly FIX_RATE_MAX=20
readonly FIX_RATE_MIN_COMMITS=5
readonly TEST_GAP_MAX=20
readonly FACTS_WINDOW_SECONDS=31536000
readonly FACTS_MAX=5
readonly FACTS_SUBJECT_BYTES=160

die() { printf 'git-recon: %s\n' "$*" >&2; exit 1; }

facts_cleanup() {
  [[ -z "${temp_dir:-}" ]] || rm -rf "$temp_dir" 2>/dev/null || true
  temp_dir=''
}

facts_error() {
  facts_cleanup
  trap - EXIT INT TERM
  printf '{"v":1,"error":{"code":"%s","message":"%s"}}\n' "$1" "$2"
  exit 1
}

usage() {
  cat <<'EOF'
git-recon — investigate a codebase through its git history

Usage: git-recon <command> [args]

First pass:
  overview             recent activity, churn, ownership, repairs in one shot

Drill-down (after overview points somewhere):
  hotspot <path>       commit history with per-commit stats for one path
  owners <path>        top contributors for a file/dir
  blame [-L a,b] <file>  whitespace-insensitive blame with short dates

Deeper analysis:
  deep                 coupling, risk, silos, fix-rate, test-gap in one shot
  coupling [<path>]    files that change together, last year
  risk                 churn weighted by current indentation complexity
  silos                majority ownership and inactive-owner risk
  fix-rate             repair-shaped commits as a share of file changes
  test-gap             logic changes accompanied by test changes

Individual sections (subsets of overview):
  vitals               repo scale: commit/file/author counts and concentration
  recent               commit stream, last 90 days
  churn                most-changed files, last year
  churn-dirs           most-changed directories, last year
  authors              active contributors, last 6 months
  repairs              bug-fix-shaped files + incident/rollback commits
  monthly              commit volume by month (full history)

Guidance:
  explain              how to interpret each section (read once first)

Automated interface:
  facts --format=json [--at REV] [-L a,b] -- PATH
                       bounded, versioned history facts as compact JSON
EOF
}

explain() {
  cat <<'EOF'
git-recon: interpreting the output
===================================

Purpose: before reading code in an unfamiliar repo, use history to decide
what to read first. Churn and repair patterns expose recurring behavior over
time, not just the current snapshot.

Recommended sequence:
  1. git-recon overview
  2. For risk or instability work, run git-recon deep.
  3. Pick a suspicious file or directory from the resulting signals.
  4. git-recon hotspot <path>   — what does its history look like?
  5. git-recon owners <path>    — who is likely to have context?
  6. git-recon blame -L a,b <file> — who last touched those lines?
  7. Read the code with that context.

Section notes and caveats:

vitals      Scale calibration for every other section: 42 commits on a file
            means something different in a 300-commit repo than a 90k-commit
            monorepo. The author line is a rough bus-factor hint; "recent
            commits" counts across all refs, no merges.

recent      Cadence, naming style, revert frequency; whether bots or release
            commits dominate. Fastest feel for the repo's current workflow.

churn       High churn suggests complexity, instability, or active product
churn-dirs  work. First check whether top entries are real logic or expected
            glue (routes, lockfiles, generated code). churn-dirs is more
            useful than churn in large repos. The share footer says how much
            of total change activity the capped list covers: a high share
            means hotspot-driven, a low share means change is spread out and
            the ranking matters less.

authors     Current-activity hint, not bus factor. Who has recent context.

repairs     == bug-files ==   files recurring in commits whose message matches
            fix|bug|broken. Commit-message heuristic — quality of the signal
            depends on commit-message discipline in the repo.
            == firefights ==  commits matching revert|hotfix|emergency|rollback.
            Narrower and more operational; good for spotting instability or
            rollback-heavy periods.

coupling    Files that often change in the same commit. High counts suggest
            coordination or a hidden dependency; pass a path to focus on its
            partners. Commits over 30 files are skipped as likely sweeps, and
            the one-year window can miss older or slower-moving relationships.

risk        One-year churn weighted by current lines times maximum indentation
            depth. High scores prioritize hot, structurally dense files over
            routine glue. Indentation is only a complexity proxy; current-tree
            complexity is combined with historical churn, so renames and large
            rewrites can make the two sides of the score disagree.

silos       For hot files, the majority author, their commit share, and whether
            they are active in the last six months. High-share INACTIVE entries
            flag orphaned-knowledge risk. Commit counts are not line ownership
            and do not capture reviews, pairing, or uncommitted expertise.

fix-rate    Repair-shaped commits divided by all commits for frequently changed
            files. High rates suggest repeated repair relative to activity;
            files need at least five commits. Like repairs, this depends on
            commit-message discipline and is not a defect-rate measurement.

test-gap    For hot non-test files, the share of commits that also changed a
            test file; low values are the gap signal. This is the flakiest
            heuristic here: path naming drives classification, so monorepos and
            unconventional test layouts can break it.

monthly     Rough activity trend. Not a team-health metric; volume is heavily
            shaped by workflow (squash vs merge, bots, release automation).

hotspot     Per-commit stats for one path. Look for repeated repair work,
            large edits, or a long tail of small patches. Capped at 25
            commits; use `git log --stat --follow -- <path>` for everything.

owners      Commit counts for one path. More useful than repo-wide counts
            when you are already focused on an area.

blame       Whitespace-insensitive, so formatting-only changes don't
            distract. Add `-L start,end` before the file to focus on a range.

General caveats:
- All of this is signal, not proof. Corroborate before concluding.
- Shallow clones and squash-merge workflows weaken every section.
- jj-native repos (no .git directory) are not supported; use `jj` directly.
EOF
}

# Caps ranked "count name" lines from stdin at $1 rows and appends a share
# footer, so a truncated list still says how much of the total it covers
# (whether the repo is hotspot-driven or the distribution is flat).
share_cap() {
  awk -v max="$1" -v noun="$2" '
    {
      total_changes += $1
      total_names++
      if (NR <= max) {
        shown += $1
        print
      }
    }
    END {
      if (total_changes > 0) {
        printf "(top %d of %d %s = %d%% of %d changes in last year)\n",
          (total_names < max ? total_names : max), total_names, noun,
          int(100 * shown / total_changes), total_changes
      }
    }'
}

vitals() {
  [[ $# -eq 0 ]] || die 'usage: git-recon vitals'
  local first_date total_commits window_commits touched tracked all_authors

  first_date="$(git log --reverse --date=short --format=%ad | head -1)"
  total_commits="$(git rev-list --count HEAD)"
  window_commits="$(git rev-list --count --since="$CHURN_WINDOW" HEAD)"
  touched="$(git log --format=format: --name-only --since="$CHURN_WINDOW" \
    | sed '/^$/d' | sort -u | wc -l | tr -d ' ')"
  tracked="$(git ls-files | wc -l | tr -d ' ')"
  all_authors="$(git shortlog -sn --all --no-merges | wc -l | tr -d ' ')"

  printf 'commits: %s all-time (first %s), %s in last year\n' \
    "$total_commits" "$first_date" "$window_commits"
  printf 'files: %s touched in last year, %s tracked\n' "$touched" "$tracked"
  git shortlog -sn --since="$AUTHORS_WINDOW" --all --no-merges \
    | awk -v all="$all_authors" '
        NR == 1 {
          top_count = $1
          top = $0
          sub(/^[[:space:]]*[0-9]+[[:space:]]+/, "", top)
        }
        { active++; recent += $1 }
        END {
          if (recent > 0) {
            printf "authors: %d active in last 6 months of %d all-time; ",
              active, all
            printf "top: %s (%d%% of recent commits)\n",
              top, int(100 * top_count / recent)
          } else {
            printf "authors: 0 active in last 6 months of %d all-time\n", all
          }
        }'
}

recent() {
  git log --date=short --pretty=format:'%ad %h %an %s' \
    --since="${RECENT_DAYS}.days.ago" | head -"$RECENT_MAX"
}

churn() {
  git log --format=format: --name-only --since="$CHURN_WINDOW" \
    | sed '/^$/d' | sort | uniq -c | sort -rn \
    | share_cap "$CHURN_MAX" files
}

churn_dirs() {
  git log --format=format: --name-only --since="$CHURN_WINDOW" \
    | sed '/^$/d' | sed 's,/[^/]*$,,' | sort | uniq -c | sort -rn \
    | share_cap "$CHURN_DIRS_MAX" dirs
}

authors() {
  git shortlog -sn --since="$AUTHORS_WINDOW" --all --no-merges \
    | head -"$AUTHORS_MAX"
}

bug_files() {
  git log -i -E --grep='fix|bug|broken' --name-only --format= \
    --since="$CHURN_WINDOW" \
    | sed '/^$/d' | sort | uniq -c | sort -rn | head -"$BUG_FILES_MAX"
}

firefights() {
  git log --oneline -i --extended-regexp --since="$CHURN_WINDOW" \
    --grep=revert --grep=hotfix --grep=emergency --grep=rollback
}

repairs() {
  echo '== bug-files =='
  bug_files
  printf '\n== firefights ==\n'
  firefights
}

monthly() {
  git log --format=%ad --date=format:%Y-%m | sort | uniq -c
}

owners() {
  [[ $# -gt 0 ]] || die 'usage: git-recon owners <path>'
  git shortlog -sn --all --no-merges -- "$@"
}

hotspot() {
  [[ $# -gt 0 ]] || die 'usage: git-recon hotspot <path>'
  git log -n "$HOTSPOT_COMMITS" --stat --follow -- "$1"
  printf '\n(last %s commits; git log --stat --follow -- %s shows all)\n' \
    "$HOTSPOT_COMMITS" "$1"
}

blame() {
  [[ $# -gt 0 ]] || die 'usage: git-recon blame [-L start,end] <file>'
  git blame -w --date=short "$@"
}

validate_facts_path() {
  local value="$1"
  local LC_ALL=C

  case "$value" in
    *[[:cntrl:]]*)
      facts_error unsupported_path_encoding \
        'path must be valid UTF-8 without control bytes'
      ;;
  esac
  printf '%s' "$value" | iconv -f UTF-8 -t UTF-8 >/dev/null 2>&1 \
    || facts_error unsupported_path_encoding \
      'path must be valid UTF-8 without control bytes'
}

json_escape() {
  local value="$1"
  value="${value//\\/\\\\}"
  value="${value//\"/\\\"}"
  printf '%s' "$value"
}

json_subject() {
  local value="$1"

  value="$(printf '%s' "$value" \
    | LC_ALL=C tr '\001-\037\177' ' ' \
    | LC_ALL=C sed 's/[[:space:]][[:space:]]*/ /g; s/^ //; s/ $//' \
    | iconv -c -f UTF-8 -t UTF-8 2>/dev/null \
    | dd bs="$FACTS_SUBJECT_BYTES" count=1 2>/dev/null \
    | iconv -c -f UTF-8 -t UTF-8 2>/dev/null)"
  json_escape "$value"
}

facts_emit_candidate_supports() {
  local path_type="$1"
  local seed_path="$2"
  local ranked_epoch="$3"
  local ranked_sha="$4"
  local output_file="$5"
  local seed_touched="$6"
  local too_large="$7"
  local changed_path
  shift 7

  [[ "$seed_touched" -eq 1 && "$too_large" -eq 0 ]] || return 0
  for changed_path in "$@"; do
    if [[ "$path_type" == 'tree' \
      && "$changed_path" == "${seed_path}/"* ]]; then
      continue
    fi
    if [[ "$path_type" != 'tree' && "$changed_path" == "$seed_path" ]]; then
      continue
    fi
    case "$changed_path" in
      /*|*[[:cntrl:]]*)
        continue
        ;;
    esac
    printf '%s\t%s\t%s\n' "$changed_path" "$ranked_epoch" \
      "$ranked_sha" >> "$output_file"
  done
}

facts() {
  local LC_ALL=C
  local format=''
  local at='HEAD'
  local line_range=''
  local range_start=''
  local range_end=''
  local line_count
  local path=''
  local pathspec
  local repo_top
  local resolved_at
  local epoch
  local since
  local escaped_path
  local temp_dir
  local blob_file
  local recent_file
  local repairs_file
  local repairs_log_file
  local ranked_file
  local log_file
  local candidate_commits_file
  local candidate_shas_file
  local candidate_diff_file
  local eligible_candidate_shas_file
  local diff_file
  local eligible_supports_file
  local unique_partners_file
  local normalized_partners_file
  local batch_paths_file
  local batch_input_file
  local batch_output_file
  local current_partners_file
  local partners_file
  local coupled_file
  local blame_file
  local blame_lines_file
  local origins_file
  local path_type
  local kind
  local ranked_epoch
  local ranked_sha
  local changed_path
  local path_count
  local seed_touched
  local too_large
  local duplicate
  local diff_token
  local current_candidate_sha=''
  local current_candidate_epoch=''
  local first_candidate_path=0
  local candidate_marker_allowed=1
  local partner
  local count
  local support_partner
  local support_epoch
  local support_sha
  local first_support_epoch
  local first_support_sha
  local support_count
  local support_indexes_json
  local response
  local escaped_partner
  local blamed_sha
  local origin_sha
  local origin_start
  local origin_end
  local origin_rows=0
  local index
  local i
  local subject
  local recent_json=''
  local repairs_json=''
  local coupled_json=''
  local origins_json=''
  local tab=$'\t'
  local base_commit_count
  local -a changed_paths=()
  local -a commit_shas=()
  local -a commit_epochs=()
  local -a commit_subjects=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --format=json)
        format='json'
        shift
        ;;
      --format=*)
        facts_error unsupported_format 'only --format=json is supported'
        ;;
      --at)
        [[ $# -ge 2 ]] \
          || facts_error invalid_arguments 'invalid facts arguments'
        at="$2"
        shift 2
        ;;
      -L)
        [[ $# -ge 2 && -z "$line_range" ]] \
          || facts_error invalid_arguments 'invalid facts arguments'
        line_range="$2"
        if [[ ! "$line_range" =~ ^([1-9][0-9]*),([1-9][0-9]*)$ ]]; then
          facts_error invalid_range \
            'line range must use positive start,end integers'
        fi
        range_start="${BASH_REMATCH[1]}"
        range_end="${BASH_REMATCH[2]}"
        [[ "$range_start" -le "$range_end" ]] \
          || facts_error invalid_range \
            'line range start must not exceed end'
        shift 2
        ;;
      --)
        shift
        [[ $# -eq 1 ]] \
          || facts_error invalid_arguments 'invalid facts arguments'
        path="$1"
        shift
        ;;
      *)
        facts_error invalid_arguments 'invalid facts arguments'
        ;;
    esac
  done

  [[ "$format" == 'json' ]] \
    || facts_error unsupported_format 'only --format=json is supported'
  [[ -n "$path" ]] \
    || facts_error invalid_arguments 'invalid facts arguments'
  command -v iconv >/dev/null 2>&1 \
    || facts_error git_failure 'required system tool is unavailable'
  validate_facts_path "$path"
  escaped_path="$(json_escape "$path")"
  pathspec=":(top,literal)${path}"
  local shallow
  shallow="$(git rev-parse --is-shallow-repository 2>/dev/null)" \
    || facts_error git_failure 'git query failed'
  [[ "$shallow" != 'true' ]] \
    || facts_error shallow_repository 'complete history is required'
  repo_top="$(git rev-parse --show-toplevel 2>/dev/null)" \
    || facts_error git_failure 'git query failed'
  resolved_at="$(git rev-parse --verify "${at}^{commit}" 2>/dev/null)" \
    || facts_error invalid_revision 'revision is not a commit'
  git cat-file -e "${resolved_at}:${path}" 2>/dev/null \
    || facts_error invalid_path 'path does not exist at revision'
  path_type="$(git cat-file -t "${resolved_at}:${path}" 2>/dev/null)" \
    || facts_error git_failure 'git query failed'
  if [[ -n "$line_range" && "$path_type" != 'blob' ]]; then
    facts_error invalid_range 'line range requires a file path'
  fi
  temp_dir="$(mktemp -d "${TMPDIR:-/tmp}/git-recon-facts.XXXXXX" 2>/dev/null)" \
    || facts_error git_failure 'git query failed'
  trap facts_cleanup EXIT
  trap 'exit 130' INT
  trap 'exit 143' TERM
  blob_file="${temp_dir}/blob"
  if [[ -n "$line_range" ]]; then
    git show "${resolved_at}:${path}" > "$blob_file" 2>/dev/null \
      || facts_error git_failure 'git query failed'
    line_count="$(awk 'END { print NR + 0 }' "$blob_file")" \
      || facts_error git_failure 'git query failed'
    [[ "$range_end" -le "$line_count" ]] \
      || facts_error invalid_range 'line range exceeds file bounds'
  fi
  epoch="$(git show -s --format=%ct "$resolved_at" 2>/dev/null)" \
    || facts_error git_failure 'git query failed'
  since="$((epoch - FACTS_WINDOW_SECONDS))"

  recent_file="${temp_dir}/recent"
  repairs_file="${temp_dir}/repairs"
  repairs_log_file="${temp_dir}/repairs-log"
  ranked_file="${temp_dir}/ranked"
  log_file="${temp_dir}/log"
  candidate_commits_file="${temp_dir}/candidate-commits"
  candidate_shas_file="${temp_dir}/candidate-shas"
  candidate_diff_file="${temp_dir}/candidate-diff"
  eligible_candidate_shas_file="${temp_dir}/eligible-candidate-shas"
  diff_file="${temp_dir}/diff"
  eligible_supports_file="${temp_dir}/eligible-supports"
  unique_partners_file="${temp_dir}/unique-partners"
  normalized_partners_file="${temp_dir}/normalized-partners"
  batch_paths_file="${temp_dir}/batch-paths"
  batch_input_file="${temp_dir}/batch-input"
  batch_output_file="${temp_dir}/batch-output"
  current_partners_file="${temp_dir}/current-partners"
  partners_file="${temp_dir}/partners"
  coupled_file="${temp_dir}/coupled"
  blame_file="${temp_dir}/blame"
  blame_lines_file="${temp_dir}/blame-lines"
  origins_file="${temp_dir}/origins"
  : > "$eligible_supports_file"

  # Fact ranks use committer epoch descending, then full SHA ascending.
  git log --format='%ct %H' "$resolved_at" -- "$pathspec" \
    > "$log_file" 2>/dev/null || facts_error git_failure 'git query failed'
  awk -v since="$since" -v cutoff="$epoch" \
      '$1 >= since && $1 <= cutoff' "$log_file" \
    | LC_ALL=C sort -k1,1nr -k2,2 \
    | head -"$FACTS_MAX" > "$recent_file"
  # Reuse the path-limited commit set when matching repair messages. Repeating
  # the path history walk produces the same candidates but is costly on hot
  # files in large repositories.
  awk '{ print $2 }' "$log_file" \
    | git log --stdin --no-walk=unsorted -i -E \
      --grep='fix|bug|broken' --format='%ct %H' 2>/dev/null \
      > "$repairs_log_file" \
    || facts_error git_failure 'git query failed'
  awk -v since="$since" -v cutoff="$epoch" \
      '$1 >= since && $1 <= cutoff' "$repairs_log_file" \
    | LC_ALL=C sort -k1,1nr -k2,2 \
    | head -"$FACTS_MAX" > "$repairs_file"
  awk '{ print "recent " $0 }' "$recent_file" > "$ranked_file"
  awk '{ print "repairs " $0 }' "$repairs_file" >> "$ranked_file"

  while read -r kind ranked_epoch ranked_sha; do
    index=-1
    for ((i = 0; i < ${#commit_shas[@]}; i++)); do
      if [[ "${commit_shas[$i]}" == "$ranked_sha" ]]; then
        index="$i"
        break
      fi
    done
    if [[ "$index" -eq -1 ]]; then
      index="${#commit_shas[@]}"
      commit_shas[index]="$ranked_sha"
      commit_epochs[index]="$ranked_epoch"
      subject="$(git show -s --encoding=UTF-8 --format=%s "$ranked_sha" \
        2>/dev/null)" || facts_error git_failure 'git query failed'
      commit_subjects[index]="$(json_subject "$subject")"
    fi
    if [[ "$kind" == 'recent' ]]; then
      [[ -z "$recent_json" ]] || recent_json="${recent_json},"
      recent_json="${recent_json}${index}"
    else
      [[ -z "$repairs_json" ]] || repairs_json="${repairs_json},"
      repairs_json="${repairs_json}${index}"
    fi
  done < "$ranked_file"

  git log --full-history --format='%ct %H' "$resolved_at" -- "$pathspec" \
    > "$log_file" 2>/dev/null || facts_error git_failure 'git query failed'
  awk -v since="$since" -v cutoff="$epoch" \
      '$1 >= since && $1 <= cutoff' "$log_file" \
    | LC_ALL=C sort -k1,1nr -k2,2 > "$candidate_commits_file"
  awk '{ print $2 }' "$candidate_commits_file" > "$candidate_shas_file"
  # Full-history merges can expand into tens of thousands of paths. First use
  # Git's quoted, line-delimited form only to count distinct paths and discard
  # oversized commits before Bash sees their complete path lists. Quoting
  # keeps control-byte paths on one line; no quoted text reaches the response.
  git -c core.quotePath=true diff-tree --stdin --root -m --name-only \
    --diff-filter=AMD -r --no-renames --pretty='format:COMMIT%x09%H' \
    < "$candidate_shas_file" > "$candidate_diff_file" 2>/dev/null \
    || facts_error git_failure 'git query failed'
  LC_ALL=C awk -F "$tab" -v max="$COUPLING_MAX_COMMIT_FILES" '
    FILENAME == ARGV[1] {
      order[++candidate_count] = $1
      next
    }
    /^COMMIT\t/ {
      sha = $2
      next
    }
    length($0) > 0 {
      key = sha SUBSEP $0
      if (!(key in paths)) {
        paths[key] = 1
        path_counts[sha]++
      }
    }
    END {
      for (i = 1; i <= candidate_count; i++) {
        sha = order[i]
        if (path_counts[sha] <= max) {
          print sha
        }
      }
    }' "$candidate_shas_file" "$candidate_diff_file" \
    > "$eligible_candidate_shas_file"
  # Re-read only eligible commits with NUL delimiters so every surviving path
  # retains its exact bytes. Carry the epoch in each marker to avoid repeatedly
  # searching the candidate list while parsing merge-parent diffs.
  git diff-tree --stdin --root -m --name-only --diff-filter=AMD -r \
    --no-renames -z --pretty='format:COMMIT%x09%ct%x09%H%x00' \
    < "$eligible_candidate_shas_file" > "$diff_file" 2>/dev/null \
    || facts_error git_failure 'git query failed'
  while IFS= read -r -d '' diff_token; do
    if [[ -z "$diff_token" ]]; then
      candidate_marker_allowed=1
      continue
    fi
    if [[ "$candidate_marker_allowed" -eq 1 \
      && "$diff_token" == "COMMIT${tab}"* ]]; then
      ranked_epoch="${diff_token#*"${tab}"}"
      ranked_sha="${ranked_epoch#*"${tab}"}"
      ranked_epoch="${ranked_epoch%%"${tab}"*}"
      if [[ -n "$current_candidate_sha" \
        && "$ranked_sha" != "$current_candidate_sha" ]]; then
        facts_emit_candidate_supports "$path_type" "$path" \
          "$current_candidate_epoch" "$current_candidate_sha" \
          "$eligible_supports_file" "$seed_touched" "$too_large" \
          "${changed_paths[@]}"
      fi
      if [[ "$ranked_sha" != "$current_candidate_sha" ]]; then
        current_candidate_sha="$ranked_sha"
        current_candidate_epoch="$ranked_epoch"
        changed_paths=()
        path_count=0
        seed_touched=0
        too_large=0
      fi
      first_candidate_path=1
      candidate_marker_allowed=0
      continue
    fi
    candidate_marker_allowed=0
    [[ -n "$current_candidate_sha" ]] \
      || facts_error git_failure 'git query failed'
    [[ "$too_large" -eq 0 ]] || continue
    changed_path="$diff_token"
    if [[ "$first_candidate_path" -eq 1 ]]; then
      changed_path="${changed_path#$'\n'}"
      first_candidate_path=0
    fi
    if [[ "$path_type" == 'tree' \
      && "$changed_path" == "${path}/"* ]]; then
      seed_touched=1
    elif [[ "$path_type" != 'tree' && "$changed_path" == "$path" ]]; then
      seed_touched=1
    fi
    duplicate=0
    for ((i = 0; i < ${#changed_paths[@]}; i++)); do
      if [[ "${changed_paths[$i]}" == "$changed_path" ]]; then
        duplicate=1
        break
      fi
    done
    [[ "$duplicate" -eq 0 ]] || continue
    changed_paths[path_count]="$changed_path"
    path_count="$((path_count + 1))"
    if [[ "$path_count" -gt "$COUPLING_MAX_COMMIT_FILES" ]]; then
      too_large=1
    fi
  done < "$diff_file"
  if [[ -n "$current_candidate_sha" ]]; then
    facts_emit_candidate_supports "$path_type" "$path" \
      "$current_candidate_epoch" "$current_candidate_sha" \
      "$eligible_supports_file" "$seed_touched" "$too_large" \
      "${changed_paths[@]}"
  fi

  cut -f1 "$eligible_supports_file" \
    | LC_ALL=C sort -u > "$unique_partners_file"
  iconv -c -f UTF-8 -t UTF-8 < "$unique_partners_file" \
    > "$normalized_partners_file" \
    || facts_error git_failure 'git query failed'
  LC_ALL=C sort -u "$normalized_partners_file" > "$batch_paths_file"
  : > "$batch_input_file"
  while IFS= read -r partner; do
    printf '%s:%s\n' "$resolved_at" "$partner" >> "$batch_input_file"
  done < "$batch_paths_file"
  git cat-file --batch-check='%(objectname)' \
    < "$batch_input_file" > "$batch_output_file" 2>/dev/null \
    || facts_error git_failure 'git query failed'
  : > "$current_partners_file"
  exec 3< "$batch_output_file"
  while IFS= read -r partner; do
    IFS= read -r response <&3 \
      || facts_error git_failure 'git query failed'
    case "$response" in
      ''|*[!0-9a-f]*) ;;
      *) printf '%s\n' "$partner" >> "$current_partners_file" ;;
    esac
  done < "$batch_paths_file"
  exec 3<&-
  LC_ALL=C awk -F "$tab" \
    'FILENAME == ARGV[1] { current[$0] = 1; next }
      $1 in current' "$current_partners_file" "$eligible_supports_file" \
    > "$partners_file"

  LC_ALL=C awk -F "$tab" '{ counts[$1]++ } END {
      for (path in counts) {
        printf "%d\t%s\n", counts[path], path
      }
    }' "$partners_file" \
    | LC_ALL=C sort -t "$tab" -k1,1nr -k2,2 \
    | head -"$FACTS_MAX" > "$coupled_file"
  base_commit_count="${#commit_shas[@]}"
  while IFS="$tab" read -r count partner; do
    support_indexes_json=''
    support_count=0
    first_support_epoch=''
    first_support_sha=''
    while IFS="$tab" read -r support_partner support_epoch support_sha; do
      [[ "$support_partner" == "$partner" ]] || continue
      if [[ -z "$first_support_sha" ]]; then
        first_support_epoch="$support_epoch"
        first_support_sha="$support_sha"
      fi
      index=-1
      for ((i = 0; i < base_commit_count; i++)); do
        if [[ "${commit_shas[$i]}" == "$support_sha" ]]; then
          index="$i"
          break
        fi
      done
      [[ "$index" -ge 0 ]] || continue
      [[ "$support_count" -lt "$FACTS_MAX" ]] || continue
      [[ -z "$support_indexes_json" ]] \
        || support_indexes_json="${support_indexes_json},"
      support_indexes_json="${support_indexes_json}${index}"
      support_count="$((support_count + 1))"
    done < "$partners_file"
    if [[ "$support_count" -eq 0 ]]; then
      index=-1
      for ((i = 0; i < ${#commit_shas[@]}; i++)); do
        if [[ "${commit_shas[$i]}" == "$first_support_sha" ]]; then
          index="$i"
          break
        fi
      done
      if [[ "$index" -eq -1 ]]; then
        index="${#commit_shas[@]}"
        commit_shas[index]="$first_support_sha"
        commit_epochs[index]="$first_support_epoch"
        subject="$(git show -s --encoding=UTF-8 --format=%s \
          "$first_support_sha" 2>/dev/null)" \
          || facts_error git_failure 'git query failed'
        commit_subjects[index]="$(json_subject "$subject")"
      fi
      support_indexes_json="$index"
    fi
    escaped_partner="$(json_escape "$partner")"
    [[ -z "$coupled_json" ]] || coupled_json="${coupled_json},"
    coupled_json="${coupled_json}[\"${escaped_partner}\",${count},"
    coupled_json="${coupled_json}[${support_indexes_json}]]"
  done < "$coupled_file"

  if [[ -n "$line_range" ]]; then
    git -C "$repo_top" blame -w --line-porcelain -L "$line_range" \
      "$resolved_at" -- "$path" > "$blame_file" 2>/dev/null \
      || facts_error git_failure 'git query failed'
    awk 'NF >= 3 && $1 ~ /^\^?[0-9a-f]+$/ && $2 ~ /^[0-9]+$/ &&
        $3 ~ /^[0-9]+$/ {
          sub(/^\^/, "", $1)
          printf "%s\t%s\n", $1, $3
        }' "$blame_file" > "$blame_lines_file"
    : > "$origins_file"
    origin_sha=''
    while IFS="$tab" read -r blamed_sha i; do
      blamed_sha="$(git rev-parse --verify "${blamed_sha}^{commit}" \
        2>/dev/null)" || facts_error git_failure 'git query failed'
      if [[ "$blamed_sha" == "$origin_sha" ]]; then
        origin_end="$i"
        continue
      fi
      if [[ -n "$origin_sha" ]]; then
        printf '%s\t%s\t%s\n' "$origin_sha" "$origin_start" \
          "$origin_end" >> "$origins_file"
        origin_rows="$((origin_rows + 1))"
        if [[ "$origin_rows" -eq "$FACTS_MAX" ]]; then
          origin_sha=''
          break
        fi
      fi
      origin_sha="$blamed_sha"
      origin_start="$i"
      origin_end="$i"
    done < "$blame_lines_file"
    if [[ -n "$origin_sha" && "$origin_rows" -lt "$FACTS_MAX" ]]; then
      printf '%s\t%s\t%s\n' "$origin_sha" "$origin_start" \
        "$origin_end" >> "$origins_file"
    fi

    while IFS="$tab" read -r origin_sha origin_start origin_end; do
      index=-1
      for ((i = 0; i < ${#commit_shas[@]}; i++)); do
        if [[ "${commit_shas[$i]}" == "$origin_sha" ]]; then
          index="$i"
          break
        fi
      done
      if [[ "$index" -eq -1 ]]; then
        index="${#commit_shas[@]}"
        commit_shas[index]="$origin_sha"
        commit_epochs[index]="$(git show -s --format=%ct "$origin_sha" \
          2>/dev/null)" || facts_error git_failure 'git query failed'
        subject="$(git show -s --encoding=UTF-8 --format=%s "$origin_sha" \
          2>/dev/null)" || facts_error git_failure 'git query failed'
        commit_subjects[index]="$(json_subject "$subject")"
      fi
      [[ -z "$origins_json" ]] || origins_json="${origins_json},"
      origins_json="${origins_json}[${index},${origin_start},${origin_end}]"
    done < "$origins_file"
  fi

  printf '{"v":1,"at":"%s","path":"%s","since":%s,' \
    "$resolved_at" "$escaped_path" "$since"
  printf '"commits":['
  for ((i = 0; i < ${#commit_shas[@]}; i++)); do
    [[ "$i" -eq 0 ]] || printf ','
    printf '["%s",%s,"%s"]' "${commit_shas[$i]}" \
      "${commit_epochs[$i]}" "${commit_subjects[$i]}"
  done
  printf '],"recent":[%s],"repairs":[%s],"coupled":[%s],' \
    "$recent_json" "$repairs_json" "$coupled_json"
  printf '"origins":[%s]}\n' "$origins_json"
  facts_cleanup
  trap - EXIT INT TERM
}

coupling() {
  [[ $# -le 1 ]] || die 'usage: git-recon coupling [<path>]'
  local target="${1:-}"

  target="${target#./}"
  target="${target%/}"
  git log --format=format:--COMMIT-- --name-only --since="$CHURN_WINDOW" \
    | awk -v max_files="$COUPLING_MAX_COMMIT_FILES" -v target="$target" '
      function matches_target(file) {
        return target != "" && (file == target || index(file, target "/") == 1)
      }
      function count_commit(    files, file_count, file, i, j, left, right, key,
                                has_target) {
        file_count = 0
        has_target = 0
        for (file in commit_files) {
          files[++file_count] = file
          if (matches_target(file)) {
            has_target = 1
          }
        }
        # Skip large commits: mass reformats/sweeps would otherwise pollute
        # every file coupling count with one unrelated one-off event.
        if (file_count > max_files) {
          return
        }
        if (target != "") {
          if (!has_target) {
            return
          }
          # Exclude files belonging to the target from its own partner
          # counts: a multi-file target (a directory) should not count
          # itself as a partner.
          for (i = 1; i <= file_count; i++) {
            if (!matches_target(files[i])) {
              counts[files[i]]++
            }
          }
          return
        }
        for (i = 1; i <= file_count; i++) {
          for (j = i + 1; j <= file_count; j++) {
            left = files[i]
            right = files[j]
            # Canonicalize left<right so pair (a,b) and (b,a) share one
            # counted key instead of splitting across two SUBSEP entries.
            if (right < left) {
              file = left
              left = right
              right = file
            }
            key = left SUBSEP right
            counts[key]++
          }
        }
      }
      /^--COMMIT--$/ {
        count_commit()
        delete commit_files
        next
      }
      NF { commit_files[$0] = 1 }
      END {
        # The final commit has no trailing --COMMIT-- sentinel to trigger
        # count_commit(), so it must be counted explicitly here.
        count_commit()
        if (target != "") {
          for (file in counts) {
            printf "%d %s\n", counts[file], file
          }
        } else {
          for (key in counts) {
            split(key, pair, SUBSEP)
            printf "%d %s -- %s\n", counts[key], pair[1], pair[2]
          }
        }
      }
    ' | sort -k1,1nr -k2,2 | head -"$COUPLING_MAX"
  printf '(top %s; commits over %s files skipped)\n' \
    "$COUPLING_MAX" "$COUPLING_MAX_COMMIT_FILES"
}

risk() {
  [[ $# -eq 0 ]] || die 'usage: git-recon risk'
  local temp_dir
  local churn_file
  local complexity_file

  temp_dir="$(mktemp -d "${TMPDIR:-/tmp}/git-recon-risk.XXXXXX")"
  churn_file="${temp_dir}/churn"
  complexity_file="${temp_dir}/complexity"

  git log --format=format: --name-only --since="$CHURN_WINDOW" \
    | awk 'NF { counts[$0]++ } END {
        for (file in counts) {
          printf "%d\t%s\n", counts[file], file
        }
      }' > "$churn_file"

  # -I -l -z selects tracked, non-binary, non-empty files (via -e ''); this
  # is the only filter that excludes binaries from the complexity score.
  # LC_ALL=C keeps xargs/awk byte-based, avoiding locale-dependent handling
  # of non-UTF8 filenames.
  # shellcheck disable=SC2016  # single-quoted awk program, not shell expansion
  git grep -Il -z -e '' \
    | LC_ALL=C xargs -0 -n 200 awk '
        function emit_file() {
          if (current_file != "") {
            printf "%d\t%s\n", lines * max_depth, current_file
          }
        }
        # xargs -0 -n 200 splits files across separate awk invocations;
        # FNR (not NR) resets per file, so FNR==1 marks a new-file boundary.
        # emit_file() flushes the previous file there, and again in END for
        # the last file of each batch (no next file left to trigger it).
        FNR == 1 {
          emit_file()
          current_file = FILENAME
          lines = 0
          max_depth = 0
        }
        {
          lines++
          match($0, /^[ \t]*/)
          indent = substr($0, 1, RLENGTH)
          spaces = 0
          tabs = 0
          for (i = 1; i <= length(indent); i++) {
            if (substr(indent, i, 1) == "\t") {
              tabs++
            } else {
              spaces++
            }
          }
          depth = tabs + int(spaces / 2)
          if (depth > max_depth) {
            max_depth = depth
          }
        }
        END { emit_file() }
      ' > "$complexity_file"

  echo 'score churn complexity file'
  # Tab-delimited (not space) since filenames may themselves contain spaces.
  # Ties break on churn, skipping complexity; filename is the final key so
  # output order is always deterministic.
  awk -F '\t' '
      FILENAME == ARGV[1] {
        separator = index($0, "\t")
        complexity[substr($0, separator + 1)] = substr($0, 1, separator - 1)
        next
      }
      {
        churn = $1
        file = substr($0, index($0, "\t") + 1)
        # Files churned but since deleted/renamed have no complexity entry
        # (built from the current tree above) and drop out here.
        if (file in complexity) {
          printf "%.0f %d %d %s\n", churn * complexity[file], churn,
            complexity[file], file
        }
      }
    ' "$complexity_file" "$churn_file" \
    | sort -k1,1nr -k2,2nr -k4,4 | head -"$RISK_MAX"
  printf '(top %s files)\n' "$RISK_MAX"
  rm -rf "$temp_dir"
}

silos() {
  [[ $# -eq 0 ]] || die 'usage: git-recon silos'
  local temp_dir
  local top_files
  local active_authors

  temp_dir="$(mktemp -d "${TMPDIR:-/tmp}/git-recon-silos.XXXXXX")"
  top_files="${temp_dir}/top-files"
  active_authors="${temp_dir}/active-authors"

  git log --format=format: --name-only --since="$CHURN_WINDOW" \
    | sed '/^$/d' | sort | uniq -c | sort -rn | head -"$SILOS_MAX" \
    | sed 's/^[[:space:]]*[0-9][0-9]*[[:space:]]//' > "$top_files"
  # Uncapped (no head): this only tests set membership, unlike the
  # head-capped display sections, so every active author must be present.
  git shortlog -sn --since="$AUTHORS_WINDOW" --all --no-merges \
    | sed 's/^[[:space:]]*[0-9][0-9]*[[:space:]]*//' > "$active_authors"

  git log --format=format:--AUTHOR--%an --name-only --since="$CHURN_WINDOW" \
    | awk '
        FILENAME == ARGV[1] { top[$0] = 1; next }
        FILENAME == ARGV[2] { active[$0] = 1; next }
        /^--AUTHOR--/ {
          # --AUTHOR-- sentinel is 10 chars; substr from 11 strips it,
          # leaving the %an name that follows on the same line.
          author = substr($0, 11)
          next
        }
        NF && ($0 in top) {
          total[$0]++
          author_count[$0 SUBSEP author]++
        }
        END {
          for (file in top) {
            majority = ""
            majority_count = 0
            # for-in order is unspecified; break ties by author name so
            # the majority pick does not vary run-to-run on equal counts.
            for (key in author_count) {
              split(key, parts, SUBSEP)
              if (parts[1] == file &&
                  (author_count[key] > majority_count ||
                   (author_count[key] == majority_count &&
                    (majority == "" || parts[2] < majority)))) {
                majority = parts[2]
                majority_count = author_count[key]
              }
            }
            if (total[file] > 0) {
              share = int(100 * majority_count / total[file])
              state = (majority in active) ? "active" : "INACTIVE"
              printf "%d%% %s %s %s\n", share, state, majority, file
            }
          }
        }
      ' "$top_files" "$active_authors" - \
    | sort -k1,1nr -k2,2 -k4,4 | head -"$SILOS_MAX"
  printf '(top %s churn files)\n' "$SILOS_MAX"
  rm -rf "$temp_dir"
}

fix_rate() {
  [[ $# -eq 0 ]] || die 'usage: git-recon fix-rate'
  local temp_dir
  local total_file
  local fixes_file

  temp_dir="$(mktemp -d "${TMPDIR:-/tmp}/git-recon-fix-rate.XXXXXX")"
  total_file="${temp_dir}/total"
  fixes_file="${temp_dir}/fixes"

  git log --format=format: --name-only --since="$CHURN_WINDOW" \
    | awk 'NF { counts[$0]++ } END {
        for (file in counts) {
          printf "%d\t%s\n", counts[file], file
        }
      }' > "$total_file"
  git log -i -E --grep='fix|bug|broken' --name-only --format= \
    --since="$CHURN_WINDOW" \
    | awk 'NF { counts[$0]++ } END {
        for (file in counts) {
          printf "%d\t%s\n", counts[file], file
        }
      }' > "$fixes_file"

  awk -F '\t' -v minimum="$FIX_RATE_MIN_COMMITS" '
      FILENAME == ARGV[1] {
        separator = index($0, "\t")
        total[substr($0, separator + 1)] = substr($0, 1, separator - 1)
        next
      }
      FILENAME == ARGV[2] {
        separator = index($0, "\t")
        fixes[substr($0, separator + 1)] = substr($0, 1, separator - 1)
        next
      }
      END {
        for (file in total) {
          # Floor avoids noisy rates from tiny samples (e.g. 1/1 = 100%).
          if (total[file] >= minimum) {
            fix_count = (file in fixes) ? fixes[file] : 0
            rate = int(100 * fix_count / total[file])
            printf "%d%% %d/%d %s\n", rate, fix_count, total[file], file
          }
        }
      }
    ' "$total_file" "$fixes_file" \
    | sort -k1,1nr -k2,2r -k3,3 | head -"$FIX_RATE_MAX"
  printf '(top %s; files need at least %s commits)\n' \
    "$FIX_RATE_MAX" "$FIX_RATE_MIN_COMMITS"
  rm -rf "$temp_dir"
}

test_gap() {
  [[ $# -eq 0 ]] || die 'usage: git-recon test-gap'
  local temp_dir
  local top_files

  temp_dir="$(mktemp -d "${TMPDIR:-/tmp}/git-recon-test-gap.XXXXXX")"
  top_files="${temp_dir}/top-files"

  git log --format=format: --name-only --since="$CHURN_WINDOW" \
    | sed '/^$/d' | sort | uniq -c | sort -rn \
    | awk '
        function is_test(file) {
          return file ~ /(^|\/)(test|tests|spec|__tests__)\// ||
            file ~ /(^|\/)[^\/]+_(test|spec)\.[^\/]+$/ ||
            file ~ /(^|\/)[^\/]+\.(test|spec)\.[^\/]+$/
        }
        {
          sub(/^[[:space:]]*[0-9][0-9]*[[:space:]]/, "")
          if (!is_test($0)) {
            printf "%s\n", $0
            found++
            # Exiting early (not breaking) stops reading the piped input;
            # like piping into head, this can SIGPIPE the upstream sort,
            # which is exactly why this script does not set pipefail.
            if (found == max_files) {
              exit
            }
          }
        }
      ' max_files="$TEST_GAP_MAX" > "$top_files"

  git log --format=format:--COMMIT-- --name-only --since="$CHURN_WINDOW" \
    | awk '
        function is_test(file) {
          return file ~ /(^|\/)(test|tests|spec|__tests__)\// ||
            file ~ /(^|\/)[^\/]+_(test|spec)\.[^\/]+$/ ||
            file ~ /(^|\/)[^\/]+\.(test|spec)\.[^\/]+$/
        }
        function count_commit(    file, has_test) {
          has_test = 0
          for (file in commit_files) {
            if (is_test(file)) {
              has_test = 1
            }
          }
          # has_test is commit-wide: any test file in the commit marks
          # every one of its top files covered, not just files whose own
          # tests changed in that commit.
          for (file in commit_files) {
            if (file in top) {
              total[file]++
              if (has_test) {
                covered[file]++
              }
            }
          }
        }
        FILENAME == ARGV[1] { top[$0] = 1; next }
        /^--COMMIT--$/ {
          count_commit()
          delete commit_files
          next
        }
        NF { commit_files[$0] = 1 }
        END {
          count_commit()
          for (file in top) {
            if (total[file] > 0) {
              rate = int(100 * covered[file] / total[file])
              printf "%d%% %d %s\n", rate, total[file], file
            }
          }
        }
      ' "$top_files" - \
    | sort -k1,1n -k2,2nr -k3,3 | head -"$TEST_GAP_MAX"
  printf '(top %s non-test churn files)\n' "$TEST_GAP_MAX"
  rm -rf "$temp_dir"
}

deep() {
  [[ $# -eq 0 ]] || die 'usage: git-recon deep'
  printf '== coupling (last year, top %s pairs) ==\n' "$COUPLING_MAX"
  coupling
  printf '\n== risk (last year, top %s files) ==\n' "$RISK_MAX"
  risk
  printf '\n== silos (last year, top %s churn files) ==\n' "$SILOS_MAX"
  silos
  printf '\n== fix-rate (last year, top %s files) ==\n' "$FIX_RATE_MAX"
  fix_rate
  printf '\n== test-gap (last year, top %s churn files) ==\n' "$TEST_GAP_MAX"
  test_gap
}

overview() {
  printf '== vitals ==\n'
  vitals
  printf '\n== recent (last %s days, first %s) ==\n' "$RECENT_DAYS" "$RECENT_MAX"
  recent
  printf '\n\n== churn (last year, top %s files) ==\n' "$CHURN_MAX"
  churn
  printf '\n== churn-dirs (last year, top %s dirs) ==\n' "$CHURN_DIRS_MAX"
  churn_dirs
  printf '\n== authors (last 6 months, top %s) ==\n' "$AUTHORS_MAX"
  authors
  printf '\n== repairs (last year) ==\n\n'
  repairs
}

main() {
  local cmd="${1:-help}"
  shift || true

  case "$cmd" in
    help|-h|--help) usage; exit 0 ;;
    explain) explain; exit 0 ;;
  esac

  if [[ "$cmd" == 'facts' ]]; then
    git rev-parse --git-dir >/dev/null 2>&1 \
      || facts_error not_repository 'not a git repository'
    facts "$@"
    exit 0
  fi

  git rev-parse --git-dir >/dev/null 2>&1 \
    || die 'not a git repository (jj-native repos unsupported; use jj directly)'

  case "$cmd" in
    overview)   overview ;;
    vitals)     vitals "$@" ;;
    recent)     recent; echo ;;
    churn)      churn ;;
    churn-dirs) churn_dirs ;;
    authors)    authors ;;
    repairs)    repairs ;;
    monthly)    monthly ;;
    owners)     owners "$@" ;;
    hotspot)    hotspot "$@" ;;
    blame)      blame "$@" ;;
    deep)       deep "$@" ;;
    coupling)   coupling "$@" ;;
    risk)       risk "$@" ;;
    silos)      silos "$@" ;;
    fix-rate)   fix_rate "$@" ;;
    test-gap)   test_gap "$@" ;;
    *)          usage >&2; die "unknown command: $cmd" ;;
  esac
}

main "$@"
